              "raw": "{\n  \"title\": \"Website Redesign\",\n  \"clientName\": \"Acme Corp\",\n  \"description\": \"Redesign the marketing site\",\n  \"budget\": 3500,\n  \"status\": \"Pending\",\n  \"deadline\": \"2026-09-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            },
            "description": "Creates a project and stores its id in `projectId` for the Update/Delete requests."
